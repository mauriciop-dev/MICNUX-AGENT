{
  "version": 2,
  "functions": {
    "api/webhook.js": {
      "memory": 1024,
      "maxDuration": 10
    },
    "api/notify.js": {
      "memory": 128,
      "maxDuration": 5
    }
  },
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.js"
    },
    {
      "src": "/api/notify",
      "dest": "/api/notify.js"
    }
  ]
}
